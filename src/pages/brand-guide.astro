---

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Import brand guidelines as raw text at build time
const brandGuideContent = await import('../../docs/brand-guidelines.md?raw').then(m => m.default).catch(() => 'Error loading brand guidelines.');
---

<BaseLayout title="Brand Guidelines" description="Visual identity, voice, and tone for the CC4.Marketing platform.">
  <Header />
  
  <div class="brand-hero">
    <div class="container text-center">
      <div class="section-label">Identity System</div>
      <h1 class="page-title">Brand Guidelines</h1>
      <p class="subtitle">The style, voice, and visual identity behind Claude Code for Marketers.</p>
    </div>
  </div>

  <div class="container main-content grid-layout">
    <aside class="sidebar">
      <nav class="sticky-nav">
        <ul>
          <li><a href="#visual">Visual Identity</a></li>
          <li><a href="#voice">Voice & Tone</a></li>
          <li><a href="#usage">Usage Contexts</a></li>
          <li><a href="#ai-rules">AI Developer Guidelines</a></li>
        </ul>
      </nav>
    </aside>

    <main class="content-area">
      <!-- Visual Identity -->
      <section id="visual" class="guide-section">
        <div class="section-header">
          <div class="section-label">Aesthetics</div>
          <h2 class="section-title">Visual Identity</h2>
          <p class="section-description"><strong>Retro-Futuristic:</strong> Blending 90s/early 2000s tech aesthetics with modern, clean layouts. It feels nostalgic yet cutting-edge—like the terminal has come to life.</p>
        </div>
        
        <h3 class="subsection-title">Core Colors</h3>
        <p class="readable-text">The CC4.Marketing palette is heavily saturated but earth-toned. These colors are used to build a chunky, rich interface.</p>
        <div class="color-grid">
          <div class="color-swatch item-stagger-1">
            <div class="swatch-color" style="background: var(--rust)"></div>
            <div class="swatch-info">
              <span class="color-name">Rust</span>
              <span class="hex-val">#B85C3C</span>
              <code>var(--rust)</code>
            </div>
          </div>
          <div class="color-swatch item-stagger-2">
            <div class="swatch-color" style="background: var(--olive)"></div>
            <div class="swatch-info">
              <span class="color-name">Olive</span>
              <span class="hex-val">#6B8E23</span>
              <code>var(--olive)</code>
            </div>
          </div>
          <div class="color-swatch item-stagger-3">
            <div class="swatch-color" style="background: var(--mustard)"></div>
            <div class="swatch-info">
              <span class="color-name">Mustard</span>
              <span class="hex-val">#E8B923</span>
              <code>var(--mustard)</code>
            </div>
          </div>
          <div class="color-swatch item-stagger-4">
            <div class="swatch-color" style="background: var(--plum)"></div>
            <div class="swatch-info">
              <span class="color-name">Plum</span>
              <span class="hex-val">#5C3A6B</span>
              <code>var(--plum)</code>
            </div>
          </div>
        </div>

        <h3 class="subsection-title mt-xl">Typography Hierarchy</h3>
        <p class="readable-text">Our typography balances a stylized, geometric display font for impact with a highly legible sans-serif for comfortable reading.</p>
        
        <div class="type-specimen headings item-stagger-1">
          <span class="type-badge">Headings & Display (Righteous)</span>
          <div class="type-showcase">Aa</div>
          <p class="type-demo">The quick brown fox jumps over the lazy dog</p>
          <div class="type-usage">Used for H1-H6, section labels, big numbers. Creates the retro-tech vibe.</div>
        </div>
        
        <div class="type-specimen body-font item-stagger-2">
          <span class="type-badge">Body (Outfit)</span>
          <div class="type-showcase">Aa</div>
          <p class="type-demo">The quick brown fox jumps over the lazy dog</p>
          <div class="type-usage">Used for paragraphs, buttons, UI elements. Reading speed and comfort are prioritized here.</div>
        </div>

        <h3 class="subsection-title mt-xl">Structural Elements</h3>
        <div class="ui-examples item-stagger-1">
          <a href="#" class="btn btn-primary" onclick="event.preventDefault()">Primary Button</a>
          <a href="#" class="btn btn-secondary" onclick="event.preventDefault()">Secondary Button</a>
        </div>
        <p class="readable-text text-sm mt-md form-notes">
          <strong>Key Rule:</strong> We use solid, hard-edged drop shadows (<code>8px 8px 0 var(--border-color)</code>) and thick 3px borders to reinforce a chunky physical aesthetic. Pure CSS blur shadows should be avoided.
        </p>
      </section>

      <!-- Voice & Tone -->
      <section id="voice" class="guide-section">
        <div class="section-header">
          <div class="section-label">Personality</div>
          <h2 class="section-title">Voice & Tone</h2>
          <p class="section-description">How we sound to the marketers reading our material.</p>
        </div>

        <div class="archetype-box item-stagger-1">
          <h3>The "10x Mentor"</h3>
          <p>Professional but approachable, deeply knowledgeable, highly actionable, and encouraging. We skip the fluff because we respect a marketer's time. We want users to feel empowered and incredibly capable.</p>
        </div>

        <div class="dos-donts mt-lg">
          <div class="do-box item-stagger-2">
            <div class="box-icon tick">✓</div>
            <h4>Do: Actionable & Empowering</h4>
            <ul>
              <li>Focus strictly on the outcome (e.g., "Ship faster").</li>
              <li>Use formatting smartly (bolding, lists for scannability).</li>
              <li>Use empowering language ("Build your AI team").</li>
              <li>Start CTAs with strong verbs.</li>
            </ul>
          </div>
          <div class="dont-box item-stagger-3">
            <div class="box-icon cross">✗</div>
            <h4>Don't: Academic or Fluffy</h4>
            <ul>
              <li>Sound robotic or overly academic about LLM theory.</li>
              <li>Write long walls of text without visual breaks.</li>
              <li>Use hype-words ("revolutionize", "game-changer") without backing them up.</li>
              <li>Use passive voice for instructions.</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Usage Contexts -->
      <section id="usage" class="guide-section">
        <div class="section-header">
          <div class="section-label">Applications</div>
          <h2 class="section-title">Usage Contexts</h2>
          <p class="section-description">Specific applications of the brand rules across different copy elements.</p>
        </div>

        <div class="table-responsive item-stagger-1">
          <table class="usage-table">
            <thead>
              <tr>
                <th>Element Context</th>
                <th>Stylistic Goal</th>
                <th>Example Implementation</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Headlines (H1-H2)</strong></td>
                <td>Benefit-focused, punchy, under 8 words.</td>
                <td>"Work 10x Faster In Claude Code."</td>
              </tr>
              <tr>
                <td><strong>Body Copy</strong></td>
                <td>Clear, concise, modular. No 5-line paras.</td>
                <td>"Claude guides you through each lesson. You create real marketing files as you learn."</td>
              </tr>
              <tr>
                <td><strong>CTAs (Buttons/Links)</strong></td>
                <td>Action-oriented, direct, unmissable.</td>
                <td>"Download Course →"</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- AI Machinability Section -->
      <section id="ai-rules" class="guide-section ai-section item-stagger-1 mt-2xl">
        <div class="terminal-header">
          <div class="terminal-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="terminal-title">~/cc4m/brand-context > ./generate</div>
        </div>
        
        <div class="terminal-body">
          <div class="ai-header">
            <div>
              <h3>AI Developer Context</h3>
              <p class="ai-desc">Machine-readable brand guidelines intended for AI Agents to ingest for proper persona and UI element context generation.</p>
            </div>
            <div class="ai-actions">
              <button id="toggleAiRules" class="btn btn-secondary btn-sm">Reveal Context</button>
              <button id="copyAiRules" class="btn btn-primary btn-sm">Copy System Prompt</button>
            </div>
          </div>
          
          <!-- The sr-only block for AI agents -->
          <div id="aiRulesContent" class="sr-only">
            <div class="ai-rules-container mt-md">
              <div class="code-label">brand-guidelines.md</div>
              <pre><code id="aiBrandText">{brandGuideContent}</code></pre>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <Footer />
</BaseLayout>

<script>
  // Client-side interactions
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('toggleAiRules');
    const copyBtn = document.getElementById('copyAiRules');
    const aiContent = document.getElementById('aiRulesContent');
    const aiTextContent = document.getElementById('aiBrandText');

    if (toggleBtn && aiContent) {
      toggleBtn.addEventListener('click', () => {
        aiContent.classList.toggle('sr-only');
        aiContent.classList.toggle('visible-ai-content');
        if (aiContent.classList.contains('sr-only')) {
          toggleBtn.textContent = 'Reveal Context';
        } else {
          toggleBtn.textContent = 'Hide Context';
        }
      });
    }

    if (copyBtn && aiTextContent) {
      copyBtn.addEventListener('click', () => {
        const textToCopy = aiTextContent.innerText;
        navigator.clipboard.writeText(textToCopy).then(() => {
          const originalText = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.add('copied');
          
          setTimeout(() => {
            if(copyBtn) {
              copyBtn.textContent = originalText;
              copyBtn.classList.remove('copied');
            }
          }, 2000);
        }).catch(err => {
          console.error('Failed to copy text: ', err);
        });
      });
    }
  });
</script>

<style>
  /* Local Spacing Utilities referencing Global CSS */
  .mt-md { margin-top: var(--space-md); }
  .mt-lg { margin-top: var(--space-lg); }
  .mt-xl { margin-top: var(--space-xl); }
  .mt-2xl { margin-top: var(--space-2xl); }
  
  /* Readable Text Width Control */
  .readable-text {
    max-width: 70ch;
    font-size: 1.1em;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    color: var(--text-secondary);
  }

  /* Hero Section Refined */
  .brand-hero {
    padding: 100px 24px 80px;
    background: linear-gradient(135deg, var(--bg-primary) 0%, rgba(232, 185, 35, 0.1) 100%);
    border-bottom: 4px solid var(--border-color);
    margin-bottom: var(--space-2xl);
    position: relative;
    overflow: hidden;
  }
  
  html[data-theme="dark"] .brand-hero {
    background: linear-gradient(135deg, var(--bg-primary) 0%, rgba(255, 209, 71, 0.05) 100%);
  }

  .brand-hero::before {
    content: '';
    position: absolute;
    width: 300px;
    height: 300px;
    border: 3px dashed var(--mustard);
    border-radius: 50%;
    top: -100px;
    right: -50px;
    opacity: 0.2;
    z-index: 0;
  }
  
  .brand-hero .container {
    position: relative;
    z-index: 1;
  }
  
  .brand-hero .section-label {
    display: inline-block;
    background: var(--border-color);
    color: var(--bg-primary);
    padding: 4px 16px;
    margin-bottom: var(--space-lg);
  }

  html[data-theme="dark"] .brand-hero .section-label {
    background: var(--mustard);
    color: var(--ink-on-mustard);
  }

  .page-title {
    font-size: 4.5rem;
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
    animation: slideInDown 0.6s ease-out;
  }

  .brand-hero .subtitle {
    font-size: 1.4rem;
    color: var(--text-secondary);
    max-width: 650px;
    margin: 0 auto;
    font-weight: 500;
    line-height: 1.6;
    animation: slideInUp 0.6s ease-out 0.2s both;
  }

  /* Grid & Layout Refined */
  .grid-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-2xl);
    align-items: start;
    margin-bottom: 120px;
  }

  .content-area {
    min-width: 0;
  }

  /* Sticky Nav Refined */
  .sticky-nav {
    position: sticky;
    top: 100px; /* enough clearance from header */
    background: var(--bg-secondary);
    padding: 24px;
    border: 3px solid var(--border-color);
    box-shadow: 6px 6px 0 var(--border-color);
  }

  .sticky-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sticky-nav li {
    margin-bottom: 16px;
  }

  .sticky-nav li:last-child {
    margin-bottom: 0;
  }

  .sticky-nav a {
    color: var(--text-primary);
    font-weight: 600;
    display: block;
    padding: 6px 0;
    border-bottom: 2px solid transparent;
  }

  .sticky-nav a:hover, .sticky-nav a:focus {
    color: var(--rust);
    padding-left: 10px;
    border-bottom-color: var(--rust);
    transition: all 0.2s ease;
  }

  /* Main Info Sections */
  .guide-section {
    padding-bottom: 80px;
    margin-bottom: 60px;
    border-bottom: 2px dashed rgba(44, 44, 44, 0.2);
  }
  
  html[data-theme="dark"] .guide-section {
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }
  
  .guide-section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  
  .subsection-title {
    font-size: 2rem;
    margin-bottom: var(--space-md);
    color: var(--text-primary);
  }

  /* Component Animations */
  .item-stagger-1 { animation: fadeInScale 0.5s ease-out 0.1s both; }
  .item-stagger-2 { animation: fadeInScale 0.5s ease-out 0.2s both; }
  .item-stagger-3 { animation: fadeInScale 0.5s ease-out 0.3s both; }
  .item-stagger-4 { animation: fadeInScale 0.5s ease-out 0.4s both; }

  /* Colors Swatches Refined */
  .color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-lg);
  }

  .color-swatch {
    border: 3px solid var(--border-color);
    background: var(--bg-secondary);
    box-shadow: 8px 8px 0 var(--border-color);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  
  .color-swatch:hover {
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0 var(--border-color);
  }

  .swatch-color {
    height: 120px;
    width: 100%;
    border-bottom: 3px solid var(--border-color);
  }

  .swatch-info {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .color-name {
    font-family: var(--font-display);
    font-size: 1.3em;
  }
  
  .hex-val {
    font-size: 1.1em;
    color: var(--text-secondary);
  }

  .swatch-info code {
    background: var(--bg-primary);
    padding: 4px 8px;
    font-size: 0.9em;
    border: 1px solid var(--border-color);
    font-weight: 600;
    align-self: flex-start;
  }

  /* Typography Specimens */
  .type-specimen {
    background: var(--bg-secondary);
    border: 3px solid var(--border-color);
    padding: 40px;
    margin-top: var(--space-lg);
    position: relative;
    box-shadow: 8px 8px 0 var(--border-color);
  }

  .type-badge {
    position: absolute;
    top: -16px;
    left: 24px;
    background: var(--mustard);
    color: var(--ink-on-mustard);
    padding: 6px 16px;
    font-weight: bold;
    font-size: 0.9em;
    border: 3px solid var(--border-color);
    font-family: var(--font-display);
    letter-spacing: 0.05em;
  }

  .type-showcase {
    font-size: 5rem;
    line-height: 1;
    margin-bottom: var(--space-md);
    color: var(--rust);
  }

  .headings .type-showcase, .headings .type-demo {
    font-family: var(--font-display);
  }
  
  .body-font .type-showcase, .body-font .type-demo {
    font-family: var(--font-body);
    font-weight: 700;
  }

  .type-demo {
    font-size: 1.6rem;
    margin-bottom: var(--space-lg);
    line-height: 1.3;
  }

  .type-usage {
    border-top: 2px dashed var(--border-color);
    padding-top: var(--space-md);
    color: var(--text-secondary);
    font-size: 1.05em;
    line-height: 1.6;
  }

  /* UI Examples */
  .ui-examples {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    background: var(--bg-secondary);
    padding: 40px;
    border: 3px solid var(--border-color);
    box-shadow: 8px 8px 0 var(--border-color);
  }

  /* Do/Don't Boxes Refined */
  .archetype-box {
    background: var(--olive);
    color: white;
    padding: 40px;
    border: 3px solid var(--border-color);
    box-shadow: 8px 8px 0 var(--border-color);
  }

  html[data-theme="dark"] .archetype-box {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .archetype-box h3 {
    font-size: 2.2rem;
    margin-bottom: 12px;
    color: var(--mustard);
  }
  
  .archetype-box p {
    font-size: 1.2em;
    line-height: 1.6;
    margin-bottom: 0;
  }

  .dos-donts {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .do-box, .dont-box {
    padding: 32px;
    border: 3px solid var(--border-color);
    background: var(--bg-secondary);
    position: relative;
    box-shadow: 8px 8px 0 var(--border-color);
  }

  .box-icon {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 3px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    font-weight: bold;
    color: white;
  }

  .do-box { border-top: 8px solid var(--olive); }
  .do-box .box-icon { background: var(--olive); }
  .do-box h4 { color: var(--olive); }

  .dont-box { border-top: 8px solid var(--rust); }
  .dont-box .box-icon { background: var(--rust); }
  .dont-box h4 { color: var(--rust); }

  .do-box h4, .dont-box h4 {
    margin-bottom: 20px;
    font-size: 1.5rem;
    font-family: var(--font-display);
  }

  .do-box ul, .dont-box ul {
    padding-left: 0;
    list-style: none;
  }

  .do-box li, .dont-box li {
    margin-bottom: 16px;
    padding-left: 28px;
    position: relative;
    line-height: 1.5;
    font-size: 1.1em;
  }

  .do-box li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--olive);
    font-weight: bold;
  }
  
  .dont-box li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--rust);
    font-weight: bold;
  }

  /* Usage Contexts Table */
  .table-responsive {
    overflow-x: auto;
    box-shadow: 8px 8px 0 var(--border-color);
  }
  
  .usage-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg-secondary);
    border: 3px solid var(--border-color);
    min-width: 600px;
  }

  .usage-table th, .usage-table td {
    padding: 24px;
    border: 1px solid var(--border-color);
    text-align: left;
    font-size: 1.1em;
    line-height: 1.6;
  }

  .usage-table th {
    background: var(--mustard);
    color: var(--ink-on-mustard);
    font-family: var(--font-display);
    font-size: 1.3em;
    border-bottom: 3px solid var(--border-color);
  }

  .usage-table tbody tr:nth-child(even) {
    background: var(--bg-primary);
  }

  /* AI Terminal Section */
  .terminal-header {
    background: var(--mustard);
    border: 3px solid var(--border-color);
    border-bottom: none;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  html[data-theme="dark"] .terminal-header {
    background: #3D3D3D;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .terminal-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--border-color);
  }
  
  .terminal-dots span:nth-child(1) { background: #FF5F56; }
  .terminal-dots span:nth-child(2) { background: #FFBD2E; }
  .terminal-dots span:nth-child(3) { background: #27C93F; }

  .terminal-title {
    font-family: monospace;
    font-weight: bold;
    color: var(--ink-on-mustard);
    flex: 1;
    text-align: center;
    font-size: 0.95rem;
  }
  
  html[data-theme="dark"] .terminal-title {
    color: var(--text-primary);
  }

  .terminal-body {
    background: var(--bg-secondary);
    border: 3px solid var(--border-color);
    padding: 40px;
    box-shadow: 12px 12px 0 var(--border-color);
  }

  .ai-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 24px;
  }

  .ai-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin-top: 8px;
  }

  .ai-actions {
    display: flex;
    gap: 16px;
  }

  .btn-sm {
    padding: 12px 20px;
    font-size: 0.95em;
  }
  
  /* SR Only hiding */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .visible-ai-content {
    display: block;
    animation: fadeInScale 0.4s ease-out;
  }

  .ai-rules-container {
    position: relative;
  }
  
  .code-label {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--mustard);
    color: var(--ink-on-mustard);
    padding: 4px 12px;
    font-family: monospace;
    font-weight: bold;
    border-bottom-left-radius: 4px;
    border-left: 3px solid var(--accent-teal);
    border-bottom: 3px solid var(--accent-teal);
  }

  .ai-rules-container pre {
    background: var(--charcoal);
    color: #00F5C4; /* Terminal green feel */
    padding: 40px 24px 24px;
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95em;
    line-height: 1.6;
    border: 3px solid var(--accent-teal);
    max-height: 500px;
    overflow-y: auto;
    overflow-x: hidden;
