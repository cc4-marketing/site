---

import { siteData } from '../config/siteData';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const apiUrl = siteData.changelog.apiUrl;
---

<BaseLayout
  title="Changelog"
  description="Track every update, improvement, and fix to the Claude Code for Marketers course and website. Filter by type, search, and subscribe via RSS."
  keywords={['changelog', 'updates', 'Claude Code for Marketers', 'release notes', 'course updates']}
  showCourseSchema={false}
  showBreadcrumb={false}
>
  <Header />

  <section class="cl-hero">
    <div class="cl-hero-pattern"></div>
    <div class="cl-hero-inner">
      <span class="cl-hero-label">Stay Updated</span>
      <h1 class="cl-hero-title">Changelog</h1>
      <p class="cl-hero-desc">Every update, improvement, and fix — for humans and machines alike.</p>
      <div class="cl-hero-meta" id="hero-meta"></div>
      <div class="cl-feed-links">
        <a href={`${apiUrl}/rss.xml`} target="_blank" rel="noopener" class="cl-feed-pill">RSS</a>
        <a href={`${apiUrl}/feed.json`} target="_blank" rel="noopener" class="cl-feed-pill">JSON Feed</a>
        <a href="/llms.txt" class="cl-feed-pill">llms.txt</a>
      </div>
    </div>
  </section>

  <div class="cl-controls" id="cl-controls">
    <div class="cl-controls-inner">
      <div class="cl-scope-pills">
        <button class="cl-scope cl-scope--active" data-scope="all">All</button>
        <button class="cl-scope" data-scope="site"><span class="cl-scope-icon cl-scope-icon--site"></span>Website</button>
        <button class="cl-scope" data-scope="course"><span class="cl-scope-icon cl-scope-icon--course"></span>Course</button>
      </div>
      <span class="cl-filter-sep"></span>
      <div class="cl-filter-pills">
        <button class="cl-pill cl-pill--active" data-type="all">All</button>
        <button class="cl-pill" data-type="added"><span class="cl-pill-dot cl-dot--added"></span>Added</button>
        <button class="cl-pill" data-type="changed"><span class="cl-pill-dot cl-dot--changed"></span>Changed</button>
        <button class="cl-pill" data-type="fixed"><span class="cl-pill-dot cl-dot--fixed"></span>Fixed</button>
        <button class="cl-pill" data-type="security"><span class="cl-pill-dot cl-dot--security"></span>Security</button>
      </div>
      <input type="text" class="cl-search" id="cl-search" placeholder="Search updates..." autocomplete="off" />
    </div>
  </div>

  <section class="cl-body">
    <div class="cl-body-inner">
      <div class="cl-stats" id="cl-stats"></div>

      <div class="cl-timeline" id="cl-timeline">
        <div class="cl-skeleton">
          <div class="cl-sk-bar cl-sk-bar--short"></div>
          <div class="cl-sk-card"><div class="cl-sk-bar cl-sk-bar--tiny"></div><div class="cl-sk-bar cl-sk-bar--med"></div><div class="cl-sk-bar cl-sk-bar--wide"></div></div>
          <div class="cl-sk-card"><div class="cl-sk-bar cl-sk-bar--tiny"></div><div class="cl-sk-bar cl-sk-bar--med"></div><div class="cl-sk-bar cl-sk-bar--wide"></div></div>
        </div>
      </div>

      <div class="cl-empty" id="cl-empty" style="display:none;">
        <h3>No updates found</h3>
        <p id="cl-empty-msg">Try adjusting your filters or search.</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script define:vars={{ apiUrl }}>
  const TL = { added: 'Added', changed: 'Changed', deprecated: 'Deprecated', removed: 'Removed', fixed: 'Fixed', security: 'Security' };
  const TC = { added: 'type-added', changed: 'type-changed', deprecated: 'type-deprecated', removed: 'type-removed', fixed: 'type-fixed', security: 'type-security' };

  let allEntries = [];
  let activeType = 'all';
  let activeScope = 'all';
  let searchQuery = '';

  function getScope(entry) {
    const mods = entry.modules || [];
    if (mods.includes('course')) return 'course';
    return 'site';
  }

  function fmtDate(d) {
    return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function groupByVersion(entries) {
    const g = new Map();
    for (const e of entries) {
      const v = e.version === 'unreleased' ? 'Unreleased' : e.version;
      if (!g.has(v)) g.set(v, []);
      g.get(v).push(e);
    }
    return g;
  }

  function renderEntry(entry) {
    const tc = TC[entry.type] || '';
    const label = TL[entry.type] || entry.type;
    const scope = getScope(entry);
    const scopeLabel = scope === 'course' ? 'Course' : 'Website';
    const scopeClass = scope === 'course' ? 'cl-scope-tag--course' : 'cl-scope-tag--site';
    const mods = (entry.modules || []).filter(m => m !== 'site' && m !== 'course').map(m => `<span class="cl-mod">${m}</span>`).join('');
    const ms = entry.machine_summary
      ? `<details class="cl-agent"><summary>Agent context</summary><p>${entry.machine_summary}</p></details>`
      : '';

    return `
      <div class="cl-entry">
        <div class="cl-dot ${tc}"></div>
        <div class="cl-card cl-card--${scope}">
          <div class="cl-accent ${tc}"></div>
          <div class="cl-card-body">
            <div class="cl-meta">
              <span class="cl-scope-tag ${scopeClass}">${scopeLabel}</span>
              <span class="cl-badge ${tc}">${label}</span>
              ${entry.version !== 'unreleased' ? `<span class="cl-ver">v${entry.version}</span>` : '<span class="cl-ver">unreleased</span>'}
              <span class="cl-date">${fmtDate(entry.published_at)}</span>
            </div>
            <h3 class="cl-entry-title">${entry.title}</h3>
            <p class="cl-entry-desc">${entry.summary}</p>
            ${ms}
            ${mods ? `<div class="cl-mods">${mods}</div>` : ''}
          </div>
        </div>
      </div>`;
  }

  function renderTimeline(entries) {
    const tl = document.getElementById('cl-timeline');
    const empty = document.getElementById('cl-empty');

    if (entries.length === 0) {
      tl.style.display = 'none';
      empty.style.display = 'block';
      document.getElementById('cl-empty-msg').textContent =
        activeType !== 'all' || searchQuery ? 'Try adjusting your filters or search.' : 'No updates yet. Check back soon!';
      return;
    }

    tl.style.display = 'block';
    empty.style.display = 'none';

    const groups = groupByVersion(entries);
    let html = '';
    for (const [version, items] of groups) {
      const dr = items.length === 1
        ? fmtDate(items[0].published_at)
        : `${fmtDate(items[items.length - 1].published_at)} — ${fmtDate(items[0].published_at)}`;

      const isUnreleased = version === 'Unreleased';
      const vLabel = isUnreleased ? 'Unreleased' : `v${version}`;

      html += `
        <div class="cl-vgroup ${isUnreleased ? 'cl-vgroup--unreleased' : ''}">
          <div class="cl-vheader">
            <h2 class="cl-vlabel">${vLabel}</h2>
            ${!isUnreleased ? `<span class="cl-vdate">${dr}</span>` : ''}
            <span class="cl-vcount">${items.length} update${items.length > 1 ? 's' : ''}</span>
          </div>
          <div class="cl-ventries">${items.map(renderEntry).join('')}</div>
        </div>`;
    }
    tl.innerHTML = html;
  }

  function renderStats(entries) {
    const el = document.getElementById('cl-stats');
    const siteCount = entries.filter(e => getScope(e) === 'site').length;
    const courseCount = entries.filter(e => getScope(e) === 'course').length;
    const tc = {};
    for (const e of entries) tc[e.type] = (tc[e.type] || 0) + 1;
    const dots = Object.entries(tc).map(([t, c]) =>
      `<span class="cl-stat-item"><span class="cl-stat-dot ${TC[t]}"></span>${c} ${TL[t] || t}</span>`
    ).join('');
    el.innerHTML = `<span class="cl-stat-total">${entries.length} updates</span><span class="cl-stat-sep"></span><span class="cl-stat-item"><span class="cl-stat-dot cl-stat-dot--site"></span>${siteCount} Website</span><span class="cl-stat-item"><span class="cl-stat-dot cl-stat-dot--course"></span>${courseCount} Course</span><span class="cl-stat-sep"></span>${dots}`;
  }

  function renderHeroMeta(entries) {
    const el = document.getElementById('hero-meta');
    if (!entries.length) return;
    el.innerHTML = `Latest: <strong>v${entries[0].version}</strong> — ${fmtDate(entries[0].published_at)}`;
  }

  function applyFilters() {
    let f = allEntries;
    if (activeScope !== 'all') f = f.filter(e => getScope(e) === activeScope);
    if (activeType !== 'all') f = f.filter(e => e.type === activeType);
    if (searchQuery) {
      const q = searchQuery.toLowerCase();
      f = f.filter(e => e.title.toLowerCase().includes(q) || e.summary.toLowerCase().includes(q) || (e.modules || []).some(m => m.toLowerCase().includes(q)));
    }
    renderTimeline(f);
    const p = new URLSearchParams();
    if (activeScope !== 'all') p.set('scope', activeScope);
    if (activeType !== 'all') p.set('type', activeType);
    if (searchQuery) p.set('q', searchQuery);
    const qs = p.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  function initFilters() {
    const p = new URLSearchParams(location.search);
    if (p.get('scope')) {
      activeScope = p.get('scope');
      document.querySelectorAll('.cl-scope').forEach(b => b.classList.toggle('cl-scope--active', b.dataset.scope === activeScope));
    }
    if (p.get('type')) {
      activeType = p.get('type');
      document.querySelectorAll('.cl-pill').forEach(b => b.classList.toggle('cl-pill--active', b.dataset.type === activeType));
    }
    if (p.get('q')) { searchQuery = p.get('q'); document.getElementById('cl-search').value = searchQuery; }

    document.querySelectorAll('.cl-scope').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.cl-scope').forEach(b => b.classList.remove('cl-scope--active'));
        btn.classList.add('cl-scope--active');
        activeScope = btn.dataset.scope;
        applyFilters();
      });
    });

    document.querySelectorAll('.cl-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.cl-pill').forEach(b => b.classList.remove('cl-pill--active'));
        pill.classList.add('cl-pill--active');
        activeType = pill.dataset.type;
        applyFilters();
      });
    });

    let deb;
    document.getElementById('cl-search').addEventListener('input', (e) => {
      clearTimeout(deb);
      deb = setTimeout(() => { searchQuery = e.target.value.trim(); applyFilters(); }, 250);
    });
  }

  async function load() {
    try {
      const res = await fetch(`${apiUrl}/api/changelog`);
      if (!res.ok) throw new Error();
      const data = await res.json();
      allEntries = data.entries || [];
      renderHeroMeta(allEntries);
      renderStats(allEntries);
      initFilters();
      applyFilters();
    } catch {
      document.getElementById('cl-timeline').style.display = 'none';
      document.getElementById('cl-empty').style.display = 'block';
      document.getElementById('cl-empty-msg').textContent = 'Could not load changelog. Please try again later.';
    }
  }

  load();
</script>

<style>
  /* Reset section padding from global.css */
  .cl-hero, .cl-body { padding: 0; }

  /* ── HERO ─────────────────────────────────────── */
  .cl-hero {
    background: linear-gradient(135deg, #2C2C2C 0%, #1a1a2e 100%);
    color: white;
    position: relative;
    overflow: hidden;
  }

  html[data-theme="dark"] .cl-hero {
    background: linear-gradient(135deg, #1a1a1a 0%, #111122 100%);
  }

  .cl-hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(232, 185, 35, 0.07) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .cl-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 120px 24px 56px;
    text-align: center;
  }

  .cl-hero-label {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.85em;
    color: var(--mustard);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 16px;
  }

  .cl-hero-title {
    font-family: var(--font-display);
    font-size: 3.5em;
    color: white;
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .cl-hero-desc {
    font-size: 1.15em;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 auto 20px;
    max-width: 500px;
    line-height: 1.7;
  }

  .cl-hero-meta {
    font-size: 0.9em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 20px;
  }

  .cl-hero-meta strong { color: var(--mustard); }

  .cl-feed-links {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cl-feed-pill {
    font-size: 0.78em;
    font-weight: 600;
    color: var(--mustard);
    text-decoration: none;
    border: 1px solid rgba(232, 185, 35, 0.35);
    padding: 4px 14px;
    transition: all 0.2s ease;
    letter-spacing: 0.04em;
  }

  .cl-feed-pill:hover {
    background: var(--mustard);
    color: #2C2C2C;
    border-color: var(--mustard);
  }

  /* ── CONTROLS (sticky filter bar) ─────────────── */
  .cl-controls {
    background: var(--bg-secondary);
    border-bottom: 2px solid var(--border-color);
    padding: 14px 24px;
    position: sticky;
    top: 60px;
    z-index: 10;
  }

  .cl-controls-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .cl-filter-pills {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .cl-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    font-size: 0.8em;
    font-weight: 600;
    border: 2px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: var(--font-body);
  }

  .cl-pill:hover {
    border-color: var(--mustard);
    color: var(--text-primary);
  }

  .cl-pill--active {
    background: var(--charcoal);
    color: white;
    border-color: var(--charcoal);
  }

  html[data-theme="dark"] .cl-pill--active {
    background: var(--mustard);
    color: #1a1a1a;
    border-color: var(--mustard);
  }

  .cl-pill-dot {
    width: 8px;
    height: 8px;
    display: inline-block;
    flex-shrink: 0;
  }

  .cl-dot--added { background: #6B8E23; }
  .cl-dot--changed { background: #E8B923; }
  .cl-dot--fixed { background: #B85C3C; }
  .cl-dot--security { background: #5C3A6B; }

  /* ── SCOPE PILLS ──────────────────────────────── */
  .cl-scope-pills {
    display: flex;
    gap: 4px;
  }

  .cl-scope {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    font-size: 0.8em;
    font-weight: 700;
    border: 2px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: var(--font-body);
  }

  .cl-scope:hover {
    border-color: var(--text-primary);
    color: var(--text-primary);
  }

  .cl-scope--active {
    background: var(--charcoal);
    color: white;
    border-color: var(--charcoal);
  }

  html[data-theme="dark"] .cl-scope--active {
    background: var(--mustard);
    color: #1a1a1a;
    border-color: var(--mustard);
  }

  .cl-scope-icon {
    width: 8px;
    height: 8px;
    display: inline-block;
    flex-shrink: 0;
  }

  .cl-scope-icon--site { background: #0D9488; }
  .cl-scope-icon--course { background: #5C3A6B; }

  .cl-filter-sep {
    width: 1px;
    height: 24px;
    background: var(--border-color);
    flex-shrink: 0;
  }

  .cl-search {
    flex: 1;
    min-width: 160px;
    padding: 7px 14px;
    font-size: 0.85em;
    border: 2px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .cl-search:focus { border-color: var(--mustard); }
  .cl-search::placeholder { color: var(--text-secondary); opacity: 0.5; }

  /* ── STATS RIBBON ─────────────────────────────── */
  .cl-stats {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    font-size: 0.85em;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .cl-body-inner :global(.cl-stat-total) {
    font-weight: 700;
    color: var(--text-primary);
  }

  .cl-body-inner :global(.cl-stat-sep) {
    width: 1px;
    height: 14px;
    background: var(--border-color);
    display: inline-block;
  }

  .cl-body-inner :global(.cl-stat-item) {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .cl-body-inner :global(.cl-stat-dot) {
    width: 8px;
    height: 8px;
    display: inline-block;
  }

  .cl-body-inner :global(.cl-stat-dot.type-added) { background: var(--olive); }
  .cl-body-inner :global(.cl-stat-dot.type-changed) { background: var(--mustard); }
  .cl-body-inner :global(.cl-stat-dot.type-fixed) { background: var(--rust); }
  .cl-body-inner :global(.cl-stat-dot.type-security) { background: var(--plum); }
  .cl-body-inner :global(.cl-stat-dot.type-deprecated) { background: #999; }
  .cl-body-inner :global(.cl-stat-dot.type-removed) { background: #EC4899; }
  .cl-body-inner :global(.cl-stat-dot--site) { background: #0D9488; }
  .cl-body-inner :global(.cl-stat-dot--course) { background: #5C3A6B; }

  /* ── BODY ─────────────────────────────────────── */
  .cl-body {
    background: var(--bg-primary);
    min-height: 60vh;
  }

  .cl-body-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 24px 100px;
  }

  /* ── TIMELINE ─────────────────────────────────── */
  .cl-body-inner :global(.cl-vgroup) {
    margin-bottom: 48px;
  }

  .cl-body-inner :global(.cl-vheader) {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--border-color);
    flex-wrap: wrap;
  }

  .cl-body-inner :global(.cl-vlabel) {
    font-family: var(--font-display);
    font-size: 1.5em;
    color: var(--text-primary);
    margin: 0;
    line-height: 1;
  }

  .cl-body-inner :global(.cl-vdate) {
    font-size: 0.82em;
    color: var(--text-secondary);
  }

  .cl-body-inner :global(.cl-vcount) {
    font-size: 0.78em;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 2px 10px;
    border: 1px solid var(--border-color);
  }

  .cl-body-inner :global(.cl-ventries) {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-left: 28px;
    border-left: 2px solid var(--border-color);
  }

  /* ── ENTRY ────────────────────────────────────── */
  .cl-body-inner :global(.cl-entry) {
    position: relative;
  }

  .cl-body-inner :global(.cl-dot) {
    position: absolute;
    left: -35px;
    top: 22px;
    width: 12px;
    height: 12px;
    border: 3px solid var(--bg-primary);
    box-sizing: border-box;
  }

  .cl-body-inner :global(.cl-dot.type-added) { background: var(--olive); }
  .cl-body-inner :global(.cl-dot.type-changed) { background: var(--mustard); }
  .cl-body-inner :global(.cl-dot.type-fixed) { background: var(--rust); }
  .cl-body-inner :global(.cl-dot.type-security) { background: var(--plum); }
  .cl-body-inner :global(.cl-dot.type-deprecated) { background: #999; }
  .cl-body-inner :global(.cl-dot.type-removed) { background: #EC4899; }

  .cl-body-inner :global(.cl-card) {
    display: flex;
    background: var(--bg-secondary);
    border: 3px solid var(--border-color);
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .cl-body-inner :global(.cl-card:hover) {
    transform: translate(-6px, -6px);
    box-shadow: 12px 12px 0 var(--mustard);
  }

  .cl-body-inner :global(.cl-accent) {
    width: 5px;
    flex-shrink: 0;
  }

  .cl-body-inner :global(.cl-accent.type-added) { background: var(--olive); }
  .cl-body-inner :global(.cl-accent.type-changed) { background: var(--mustard); }
  .cl-body-inner :global(.cl-accent.type-fixed) { background: var(--rust); }
  .cl-body-inner :global(.cl-accent.type-security) { background: var(--plum); }
  .cl-body-inner :global(.cl-accent.type-deprecated) { background: #999; }
  .cl-body-inner :global(.cl-accent.type-removed) { background: #EC4899; }

  .cl-body-inner :global(.cl-card-body) {
    padding: 22px 24px;
    flex: 1;
    min-width: 0;
  }

  .cl-body-inner :global(.cl-meta) {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .cl-body-inner :global(.cl-scope-tag) {
    padding: 2px 8px;
    font-size: 0.68em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1.5px solid;
  }

  .cl-body-inner :global(.cl-scope-tag--site) {
    color: #0D9488;
    border-color: #0D9488;
    background: rgba(13, 148, 136, 0.08);
  }

  .cl-body-inner :global(.cl-scope-tag--course) {
    color: #5C3A6B;
    border-color: #5C3A6B;
    background: rgba(92, 58, 107, 0.08);
  }

  html[data-theme="dark"] .cl-body-inner :global(.cl-scope-tag--site) {
    color: #2DD4BF;
    border-color: #2DD4BF;
    background: rgba(45, 212, 191, 0.1);
  }

  html[data-theme="dark"] .cl-body-inner :global(.cl-scope-tag--course) {
    color: #C084FC;
