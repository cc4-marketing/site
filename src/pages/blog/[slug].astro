---
export const prerender = false;

import { getEmDashCollection, getEmDashEntry } from 'emdash';
import { PortableText, Image } from 'emdash/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { resolveOgImage, type OgPostInput } from '../../lib/og/url';
import BlogContent from '../../components/BlogContent.astro';

const { slug } = Astro.params;
const { entry: post } = await getEmDashEntry('posts', slug!);

if (!post) {
  return Astro.redirect('/404');
}

// Fields the OG engine needs (both for the hashed URL and for JSON-LD parity).
const ogPost: OgPostInput = {
  slug: slug!,
  title: post.data.title,
  excerpt: post.data.excerpt,
  bylineIds: (post.data.bylines ?? []).map((b: { byline: { id: string } }) => b.byline.id),
  updatedAt: post.data.updatedAt ?? post.data.publishedAt ?? new Date(0),
  featuredImageSrc: post.data.featured_image?.src,
};

// Author is pulled from the post's primary byline (Emdash). Falls back to
// the house team byline so older un-backfilled posts still render cleanly.
const primaryByline = post.data.bylines?.[0]?.byline;
const authorName = primaryByline?.displayName ?? 'CC4.Marketing Team';
const authorSlug = authorName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const authorUrl = authorName === 'CC4.Marketing Team'
  ? 'https://cc4.marketing/blog/authors/'
  : `https://cc4.marketing/blog/authors/#${authorSlug}`;
const resolvedOgPath = await resolveOgImage(
  { path: Astro.url.pathname, siteUrl: 'https://cc4.marketing', engineEnabled: true },
  { post: ogPost },
);
const resolvedOgUrl = resolvedOgPath.startsWith('http')
  ? resolvedOgPath
  : `https://cc4.marketing${resolvedOgPath}`;

// Generate per-post keywords from title words + base set
const stopWords = new Set(['a', 'an', 'the', 'and', 'or', 'to', 'in', 'for', 'of', 'with', 'how', 'is', 'at', 'by', 'on', 'its', 'your', 'from', 'this', 'that', 'are', 'was', 'be', 'as', 'it', 'do', 'not', 'but', 'all', 'their', 'has', 'have', 'can', 'out', 'get', 'use', 'way', 'part', 'last', 'mile', 'best', 'why', 'what', 'when', 'will', 'into', 'our', 'more', 'most', 'new', 'its', 'one', 'two', 'just', 'now', 'then', 'also', 'very', 'like', 'make', 'work', 'need', 'look', 'even', 'back', 'only', 'well', 'than', 'over', 'after']);
const titleWords = post.data.title.toLowerCase().replace(/[^a-z0-9\s]/g, '').split(/\s+/).filter((w: string) => w.length > 2 && !stopWords.has(w));
const postKeywords = [...new Set([...titleWords.slice(0, 6), 'Claude Code', 'AI marketing'])];

function formatDate(date: Date | null | undefined): string {
  if (!date) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

// Get all published posts for prev/next nav
const { entries: allPosts } = await getEmDashCollection('posts');
const published = allPosts
  .filter((p) => p.data.status === 'published')
  .toSorted((a, b) => {
    const da = a.data.publishedAt?.getTime() ?? 0;
    const db = b.data.publishedAt?.getTime() ?? 0;
    return db - da;
  });

const currentIndex = published.findIndex((p) => p.data.slug === slug);
const prevPost = currentIndex < published.length - 1 ? published[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? published[currentIndex - 1] : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  'headline': post.data.title,
  'description': post.data.excerpt || '',
  'datePublished': post.data.publishedAt?.toISOString(),
  'dateModified': post.data.updatedAt?.toISOString(),
  'url': `https://cc4.marketing/blog/${slug}/`,
  'image': resolvedOgUrl,
  'author': {
    '@type': 'Person',
    'name': authorName,
    'url': authorUrl,
  },
  'publisher': {
    '@type': 'Organization',
    'name': 'CC4.Marketing',
    'url': 'https://cc4.marketing/',
    'logo': {
      '@type': 'ImageObject',
      'url': 'https://cc4.marketing/apple-touch-icon.png',
      'width': 180,
      'height': 180,
    },
  },
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': `https://cc4.marketing/blog/${slug}/`,
  },
  'breadcrumb': {
    '@type': 'BreadcrumbList',
    'itemListElement': [
      { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://cc4.marketing/' },
      { '@type': 'ListItem', 'position': 2, 'name': 'Blog', 'item': 'https://cc4.marketing/blog/' },
      { '@type': 'ListItem', 'position': 3, 'name': post.data.title },
    ],
  },
};

// Per-post rich result schemas — FAQPage for informational guides, HowTo for step-by-step posts.
// Keyed by slug so future posts can opt in without touching the template.
const extraSchemas: Record<string, object> = {
  'claude-code-for-marketing-guide-2026': {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': [
      {
        '@type': 'Question',
        'name': 'What is Claude Code for marketing?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Claude Code is an AI-powered CLI tool from Anthropic that lets marketers automate workflows, generate copy, analyze campaigns, and build custom AI agents — all from a terminal interface. No coding experience required.',
        },
      },
      {
        '@type': 'Question',
        'name': 'Why are marketers switching to Claude Code?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Claude Code lets marketers work 10x faster on repetitive tasks like campaign briefs, competitive research, content strategy, and copy generation. Unlike chat interfaces, it reads your actual project files and remembers context across sessions.',
        },
      },
      {
        '@type': 'Question',
        'name': 'Which marketing workflows can I automate with Claude Code?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Common automations include campaign brief generation, content calendar planning, multi-channel copy creation, competitive analysis, SEO keyword research, and campaign performance reporting.',
        },
      },
      {
        '@type': 'Question',
        'name': 'How do I get started with Claude Code for marketing?',
        'acceptedAnswer': {
          '@type': 'Answer',
          'text': 'Install Claude Code from anthropic.com, authenticate with your Anthropic account, then start the free CC4.Marketing course by typing /start-0-0. The whole setup takes under 5 minutes.',
        },
      },
    ],
  },
  'write-campaign-brief-with-ai': {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    'name': 'How to Write a Campaign Brief with AI in 10 Minutes',
    'description': 'Use Claude Code to generate a professional, multi-section campaign brief with strategic AI feedback in under 10 minutes.',
    'totalTime': 'PT10M',
    'step': [
      {
        '@type': 'HowToStep',
        'position': 1,
        'name': 'Define your campaign goal',
        'text': 'Open Claude Code and describe your campaign objective in plain language — what outcome you want, your timeline, and any constraints.',
      },
      {
        '@type': 'HowToStep',
        'position': 2,
        'name': 'Provide audience and product context',
        'text': 'Tell Claude who the target audience is, their key pain points, your product positioning, and any existing brand guidelines.',
      },
      {
        '@type': 'HowToStep',
        'position': 3,
        'name': 'Generate the structured brief',
        'text': 'Ask Claude to create a brief covering goals, audience definition, messaging hierarchy, channel strategy, and budget allocation.',
      },
      {
        '@type': 'HowToStep',
        'position': 4,
        'name': 'Run multi-perspective AI feedback',
        'text': 'Use custom reviewer sub-agents (brand voice, strategy, conversion) to identify gaps and inconsistencies before the brief is finalized.',
      },
      {
        '@type': 'HowToStep',
        'position': 5,
        'name': 'Refine and export',
        'text': 'Incorporate reviewer feedback, finalize the document, and export it for stakeholder review — typically under 10 minutes total.',
      },
    ],
  },
};
const extraSchema = extraSchemas[slug!] ?? null;

// Top-level BreadcrumbList — Google reads this independent of the
// BlogPosting nesting and uses it to render breadcrumb trails in SERP.
const breadcrumbListSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': 'https://cc4.marketing/' },
    { '@type': 'ListItem', 'position': 2, 'name': 'Blog', 'item': 'https://cc4.marketing/blog/' },
    { '@type': 'ListItem', 'position': 3, 'name': post.data.title, 'item': `https://cc4.marketing/blog/${slug}/` },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt || post.data.title}
  type="article"
  publishedDate={post.data.publishedAt?.toISOString()}
  modifiedDate={post.data.updatedAt?.toISOString()}
  ogPost={ogPost}
  author={authorName}
  keywords={postKeywords}
  showCourseSchema={false}
  showBreadcrumb={false}
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbListSchema)} />
  {extraSchema && <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />}

  <article class="blog-post">
    <div class="blog-post-inner">
      {/* Header */}
      <header class="blog-post-header">
        <a href="/blog/" class="blog-back">&larr; Back to Blog</a>
        <time class="blog-post-date" datetime={post.data.publishedAt?.toISOString()}>
          {formatDate(post.data.publishedAt)}
        </time>
        <h1 class="blog-post-title">{post.data.title}</h1>
        {post.data.excerpt && (
          <p class="blog-post-excerpt">{post.data.excerpt}</p>
        )}
        <div class="blog-post-byline">
          <span class="byline-label">By</span>
          <a href={authorUrl.replace('https://cc4.marketing', '')} class="byline-author">{authorName}</a>
        </div>
      </header>

      {/* Featured image */}
      {post.data.featured_image?.src && (
        <div class="blog-post-hero-image">
          <img
            src={post.data.featured_image.src}
            alt={post.data.featured_image.alt || post.data.title}
            width={post.data.featured_image.width}
            height={post.data.featured_image.height}
            loading="eager"
          />
        </div>
      )}

      {/* Content */}
      <div class="blog-post-content prose">
        {post.data.content && <BlogContent blocks={post.data.content} />}
      </div>

      {/* Newsletter CTA */}
      <div class="blog-post-cta">
        <h3>Get more like this</h3>
        <p>Subscribe to the CC4.Marketing newsletter for updates, guides, and practical AI marketing tips.</p>
        <a href="https://cc4marketing.substack.com" target="_blank" rel="noopener" class="blog-cta-btn">Subscribe on Substack</a>
      </div>

      {/* Prev/Next */}
      <nav class="blog-post-nav">
        {prevPost ? (
          <a href={`/blog/${prevPost.data.slug}/`} class="blog-nav-link blog-nav-prev">
            <span class="blog-nav-label">&larr; Previous</span>
            <span class="blog-nav-title">{prevPost.data.title}</span>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/blog/${nextPost.data.slug}/`} class="blog-nav-link blog-nav-next">
            <span class="blog-nav-label">Next &rarr;</span>
            <span class="blog-nav-title">{nextPost.data.title}</span>
          </a>
        ) : <div />}
      </nav>
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding: 120px 24px 80px;
  }

  .blog-post-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Back link */
  .blog-back {
    display: inline-block;
    font-size: 0.85em;
    font-weight: 600;
    color: var(--rust);
    text-decoration: none;
    margin-bottom: 32px;
    transition: opacity 0.2s;
  }

  .blog-back:hover {
    opacity: 0.7;
  }

  /* Header */
  .blog-post-header {
    margin-bottom: 40px;
  }

  .blog-post-date {
    display: block;
    font-size: 0.8em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .blog-post-title {
    font-family: var(--font-display);
    font-size: clamp(2em, 5vw, 3em);
    line-height: 1.15;
    color: var(--text-primary);
    margin: 0 0 16px;
  }

  .blog-post-excerpt {
    font-size: 1.15em;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* Byline */
  .blog-post-byline {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    font-size: 0.85em;
  }

  .byline-label {
    color: var(--text-secondary);
  }

  .byline-author {
    color: var(--rust);
    font-weight: 600;
    text-decoration: none;
  }

  .byline-author:hover {
    text-decoration: underline;
  }

  /* Featured image */
  .blog-post-hero-image {
    margin-bottom: 40px;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .blog-post-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Content - prose styles */
  .blog-post-content {
    font-size: 1.05em;
    line-height: 1.75;
    color: var(--text-primary);
    margin-bottom: 60px;
  }

  .blog-post-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6em;
    margin: 48px 0 16px;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .blog-post-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.3em;
    margin: 36px 0 12px;
    color: var(--text-primary);
  }

  .blog-post-content :global(p) {
    margin: 0 0 20px;
  }

  .blog-post-content :global(a) {
    color: var(--rust);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-post-content :global(a:hover) {
    opacity: 0.8;
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin: 0 0 20px;
    padding-left: 24px;
  }

  .blog-post-content :global(li) {
    margin-bottom: 8px;
  }

  .blog-post-content :global(blockquote) {
    border-left: 4px solid var(--rust);
    margin: 24px 0;
    padding: 12px 20px;
    background: rgba(184, 92, 60, 0.05);
    color: var(--text-secondary);
    font-style: italic;
  }

  .blog-post-content :global(code) {
    font-family: 'Fira Code', monospace;
    font-size: 0.9em;
    background: rgba(92, 58, 107, 0.08);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .blog-post-content :global(pre) {
    background: var(--charcoal);
    color: var(--cream);
    padding: 20px;
    margin: 24px 0;
    overflow-x: auto;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-sm);
  }

  .blog-post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .blog-post-content :global(img) {
    max-width: 100%;
    height: auto;
    border: 2px solid var(--border-color);
    box-shadow: var(--shadow-sm);
    margin: 24px 0;
  }

  /* Newsletter CTA */
  .blog-post-cta {
    border: 2px solid var(--rust);
    padding: 32px;
    text-align: center;
    margin-bottom: 48px;
    background: rgba(184, 92, 60, 0.04);
  }

  .blog-post-cta h3 {
    font-family: var(--font-display);
    font-size: 1.4em;
    color: var(--rust);
    margin: 0 0 8px;
  }

  .blog-post-cta p {
    color: var(--text-secondary);
    font-size: 0.95em;
    margin: 0 0 20px;
    line-height: 1.5;
  }

  .blog-cta-btn {
    display: inline-block;
    font-weight: 700;
    font-size: 0.9em;
    color: var(--cream);
    background: var(--rust);
    padding: 12px 28px;
    border: 2px solid var(--rust);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .blog-cta-btn:hover {
    background: transparent;
    color: var(--rust);
  }

  /* Prev/Next nav */
  .blog-post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    border-top: 2px solid var(--border-color);
    padding-top: 32px;
  }

  .blog-nav-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px;
    border: 2px solid var(--border-color);
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.2s ease;
  }

  .blog-nav-link:hover {
    border-color: var(--rust);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .blog-nav-next {
    text-align: right;
  }

  .blog-nav-label {
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rust);
  }

  .blog-nav-title {
    font-family: var(--font-display);
    font-size: 1em;
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .blog-post {
      padding: 100px 20px 60px;
    }

    .blog-post-nav {
      grid-template-columns: 1fr;
    }
  }
</style>
