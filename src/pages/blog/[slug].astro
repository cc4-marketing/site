---
export const prerender = false;

import { getEmDashCollection, getEmDashEntry } from 'emdash';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { resolveOgImage, type OgPostInput } from '../../lib/og/url';
import BlogContent from '../../components/BlogContent.astro';
import PostMasthead from '../../components/blog/PostMasthead.astro';
import PostToc from '../../components/blog/PostToc.astro';
import PostNav from '../../components/blog/PostNav.astro';
import PostCta from '../../components/blog/PostCta.astro';
import { slugify } from '../../lib/blog-slugify';
import { readTimeMinutes } from '../../lib/blog-read-time';
import { buildArticleSchema, buildBreadcrumbListSchema, extraSchemas } from '../../lib/blog-post-schemas';
import '../../styles/blog-prose.css';

const { slug } = Astro.params;
const { entry: post } = await getEmDashEntry('posts', slug!);

if (!post) {
  return Astro.redirect('/404');
}

// Fields the OG engine needs (both for the hashed URL and for JSON-LD parity).
const ogPost: OgPostInput = {
  slug: slug!,
  title: post.data.title,
  excerpt: post.data.excerpt,
  bylineIds: (post.data.bylines ?? []).map((b: { byline: { id: string } }) => b.byline.id),
  updatedAt: post.data.updatedAt ?? post.data.publishedAt ?? new Date(0),
  featuredImageSrc: post.data.featured_image?.src,
};

// Author is pulled from the post's primary byline (Emdash). Falls back to
// the house team byline so older un-backfilled posts still render cleanly.
const primaryByline = post.data.bylines?.[0]?.byline;
const authorName = primaryByline?.displayName ?? 'CC4.Marketing Team';
const authorSlug = authorName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
// Real authors link to their personal page; the house byline falls back to the hub.
const authorPath = authorName === 'CC4.Marketing Team'
  ? '/blog/authors/'
  : `/blog/authors/${authorSlug}/`;
const authorUrl = `https://cc4.marketing${authorPath}`;

const resolvedOgPath = await resolveOgImage(
  { path: Astro.url.pathname, siteUrl: 'https://cc4.marketing', engineEnabled: true },
  { post: ogPost },
);
const resolvedOgUrl = resolvedOgPath.startsWith('http')
  ? resolvedOgPath
  : `https://cc4.marketing${resolvedOgPath}`;

// H2 headings for the TOC; IDs come from the same slugify BlogContent uses.
const headings = (post.data.content || [])
  .filter((block: any) => block._type === 'block' && block.style === 'h2')
  .map((block: any) => {
    const text = block.children?.[0]?.text || '';
    return { text, id: slugify(text) };
  });

// Per-post keywords from title words + base set
const stopWords = new Set(['a', 'an', 'the', 'and', 'or', 'to', 'in', 'for', 'of', 'with', 'how', 'is', 'at', 'by', 'on', 'its', 'your', 'from', 'this', 'that', 'are', 'was', 'be', 'as', 'it', 'do', 'not', 'but', 'all', 'their', 'has', 'have', 'can', 'out', 'get', 'use', 'way', 'part', 'last', 'mile', 'best', 'why', 'what', 'when', 'will', 'into', 'our', 'more', 'most', 'new', 'one', 'two', 'just', 'now', 'then', 'also', 'very', 'like', 'make', 'work', 'need', 'look', 'even', 'back', 'only', 'well', 'than', 'over', 'after']);
const titleWords = post.data.title.toLowerCase().replace(/[^a-z0-9\s]/g, '').split(/\s+/).filter((w: string) => w.length > 2 && !stopWords.has(w));
const postKeywords = [...new Set([...titleWords.slice(0, 6), 'Claude Code', 'AI marketing'])];

// All published posts for prev/next
const { entries: allPosts } = await getEmDashCollection('posts');
const published = allPosts
  .filter((p) => p.data.status === 'published')
  .toSorted((a, b) => {
    const da = a.data.publishedAt?.getTime() ?? 0;
    const db = b.data.publishedAt?.getTime() ?? 0;
    return db - da;
  });

const currentIndex = published.findIndex((p) => p.data.slug === slug);
const prevPost = currentIndex < published.length - 1 ? published[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? published[currentIndex - 1] : null;

const readMinutes = readTimeMinutes(post.data.content);

const articleSchema = buildArticleSchema({
  slug: slug!,
  title: post.data.title,
  excerpt: post.data.excerpt,
  publishedAt: post.data.publishedAt,
  updatedAt: post.data.updatedAt,
  ogImageUrl: resolvedOgUrl,
  authorName,
  authorUrl,
});
const breadcrumbListSchema = buildBreadcrumbListSchema(slug!, post.data.title);
const extraSchema = extraSchemas[slug!] ?? null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt || post.data.title}
  type="article"
  publishedDate={post.data.publishedAt?.toISOString()}
  modifiedDate={post.data.updatedAt?.toISOString()}
  ogPost={ogPost}
  author={authorName}
  keywords={postKeywords}
  showCourseSchema={false}
  showBreadcrumb={false}
>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbListSchema)} />
  {extraSchema && <script type="application/ld+json" set:html={JSON.stringify(extraSchema)} />}

  {/* The desk: cream page background. The article is a bordered sheet on it. */}
  <div class="post-desk">
    <div class="post-layout">
      <article class="post-sheet">
        <PostMasthead
          title={post.data.title}
          excerpt={post.data.excerpt}
          publishedAt={post.data.publishedAt}
          authorName={authorName}
          authorPath={authorPath}
          readMinutes={readMinutes}
        />

        {/* Mobile TOC: default-closed disclosure after the masthead (R11).
            Rendered inside the sheet on mobile; the desktop sidebar variant
            in the same component renders on the desk column. */}
        {headings.length > 0 && (
          <div class="toc-slot-mobile">
            <PostToc headings={headings} variant="mobile" />
          </div>
        )}

        {/* Featured image lives inside the sheet, below the masthead (R14) */}
        {post.data.featured_image?.src && (
          <div class="post-hero-image">
            <img
              src={post.data.featured_image.src}
              alt={post.data.featured_image.alt || post.data.title}
              width={post.data.featured_image.width}
              height={post.data.featured_image.height}
              loading="eager"
            />
          </div>
        )}

        <div class="blog-post-content blog-prose">
          {post.data.content && <BlogContent blocks={post.data.content} />}
        </div>
      </article>

      {/* Desktop TOC: on the desk beside the sheet (origin R6 as reviewed) */}
      {headings.length > 0 && (
        <aside class="toc-slot-desktop">
          <PostToc headings={headings} variant="desktop" />
        </aside>
      )}
    </div>

    <div class="post-below-sheet">
      <PostCta />
      <PostNav
        prev={prevPost ? { slug: prevPost.data.slug, title: prevPost.data.title } : null}
        next={nextPost ? { slug: nextPost.data.slug, title: nextPost.data.title } : null}
      />
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
  .post-desk {
    background: var(--bg-primary);
    padding: 110px 16px 80px;
  }

  .post-layout {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 32px;
  }

  /* The sheet: bordered document on the desk. Border persists at every width
     (near full-bleed on phones, R10); the shadow is solid ink (R3). */
  .post-sheet {
    background: var(--sheet);
    border: 3px solid var(--ink-100);
    box-shadow: var(--shadow-md);
    padding: 32px clamp(16px, 4vw, 56px) 48px;
    min-width: 0; /* wide children scroll internally, never stretch the grid */
  }

  .toc-slot-mobile {
    margin-bottom: 28px;
  }

  .toc-slot-desktop {
    display: none;
  }

  .post-hero-image {
    margin: 0 0 32px;
    border: 3px solid var(--ink-100);
  }

  .post-hero-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .post-below-sheet {
    max-width: 720px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .post-layout {
      grid-template-columns: minmax(0, 1fr) 250px;
      align-items: start;
    }

    .toc-slot-mobile {
      display: none;
    }

    .toc-slot-desktop {
      display: block;
    }
  }
</style>
