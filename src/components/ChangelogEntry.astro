---
interface Props {
  title: string;
  summary: string;
  type: 'added' | 'changed' | 'deprecated' | 'removed' | 'fixed' | 'security';
  version: string;
  published_at: string;
  modules?: string[];
  style?: string;
}

const { title, summary, type, version, published_at, modules = [], style } = Astro.props;

const typeLabels: Record<string, string> = {
  added: 'Added',
  changed: 'Changed',
  deprecated: 'Deprecated',
  removed: 'Removed',
  fixed: 'Fixed',
  security: 'Security',
};

const formattedDate = new Date(published_at).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<div class="changelog-entry" style={style}>
  <div class="entry-meta">
    <span class={`type-badge type-${type}`}>{typeLabels[type] || type}</span>
    <span class="version">v{version}</span>
    <span class="date">{formattedDate}</span>
  </div>
  <h3 class="entry-title">{title}</h3>
  <p class="entry-summary">{summary}</p>
  {modules.length > 0 && (
    <div class="entry-modules">
      {modules.map((mod) => (
        <span class="module-tag">{mod}</span>
      ))}
    </div>
  )}
</div>

<style>
  .changelog-entry {
    padding: 30px;
    background: var(--bg-secondary);
    border: 3px solid var(--border-color);
    position: relative;
    transition: all 0.3s ease;
    animation: fadeInUp 0.5s ease-out backwards;
  }

  .changelog-entry:hover {
    transform: translate(-8px, -8px);
    box-shadow: 16px 16px 0 var(--mustard);
  }

  .entry-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .type-badge {
    padding: 4px 12px;
    font-size: 0.8em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
  }

  .type-added { background: var(--olive); }
  .type-changed { background: var(--mustard); color: #2C2C2C; }
  .type-fixed { background: var(--rust); }
  .type-security { background: var(--plum); }

  .version {
    font-family: var(--font-mono, monospace);
    font-size: 0.85em;
    color: var(--text-secondary);
    background: var(--bg-primary);
    padding: 2px 8px;
    border: 1px solid var(--border-color);
  }

  .date {
    font-size: 0.85em;
    color: var(--text-secondary);
  }

  .entry-title {
    font-family: var(--font-display);
    font-size: 1.3em;
    margin-bottom: 8px;
    color: var(--text-primary);
  }

  .entry-summary {
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .entry-modules {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .module-tag {
    font-size: 0.8em;
    padding: 3px 10px;
    background: rgba(107, 142, 35, 0.1);
    border: 1px solid var(--olive);
    color: var(--olive);
  }

  html[data-theme="dark"] .module-tag {
    background: rgba(107, 142, 35, 0.15);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
