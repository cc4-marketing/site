---
import { PortableText } from 'emdash/ui';

interface Props {
  blocks: any[];
}

const { blocks } = Astro.props;

// Group consecutive standard blocks so PortableText handles list wrapping.
// Custom types (code, blogImage) break the group and render directly.
type Segment =
  | { kind: 'portable'; blocks: any[]; headingId?: string }
  | { kind: 'code'; language: string; code: string; key: string }
  | { kind: 'image'; url: string; alt: string; key: string }
  | { kind: 'releaseBox'; data: any; key: string };

const segments: Segment[] = [];
let current: any[] = [];

function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9\s]/g, '').replace(/\s+/g, '-');
}

for (const block of blocks) {
  if (block._type === 'code') {
    if (current.length) { segments.push({ kind: 'portable', blocks: current }); current = []; }
    segments.push({ kind: 'code', language: block.language || 'text', code: block.code, key: block._key });
  } else if (block._type === 'blogImage') {
    if (current.length) { segments.push({ kind: 'portable', blocks: current }); current = []; }
    segments.push({ kind: 'image', url: block.url, alt: block.alt || '', key: block._key });
  } else if (block._type === 'releaseHighlight') {
    if (current.length) { segments.push({ kind: 'portable', blocks: current }); current = []; }
    segments.push({ kind: 'releaseBox', data: block, key: block._key });
  } else {
    // If this is an h2 block, flush current and start a new segment with the heading id
    if (block._type === 'block' && block.style === 'h2') {
      if (current.length) { segments.push({ kind: 'portable', blocks: current }); current = []; }
      const headingText = block.children?.[0]?.text || '';
      const headingId = slugify(headingText);
      segments.push({ kind: 'portable', blocks: [block], headingId });
    } else {
      current.push(block);
    }
  }
}
if (current.length) segments.push({ kind: 'portable', blocks: current });
---

{segments.map((seg) => {
  if (seg.kind === 'code') {
    return (
      <pre><code class={`language-${seg.language}`}>{seg.code}</code></pre>
    );
  }
  if (seg.kind === 'image') {
    return (
      <figure class="blog-inline-image">
        <img src={seg.url} alt={seg.alt} loading="lazy" />
      </figure>
    );
  }
  if (seg.kind === 'releaseBox') {
    const { version, downloadUrl, landingPageUrl, sourceUrl } = seg.data;
    return (
      <div class="blog-release-box">
        <strong>v{version}</strong>
        <p>
          Download: <a href={`https://${downloadUrl}`} target="_blank" rel="noopener noreferrer">{downloadUrl}</a><br />
          Landing page: <a href={`https://${landingPageUrl}`} target="_blank" rel="noopener noreferrer">{landingPageUrl}</a><br />
          Source: <a href={`https://${sourceUrl}`} target="_blank" rel="noopener noreferrer">{sourceUrl}</a>
        </p>
      </div>
    );
  }
  if (seg.headingId) {
    return (
      <div id={seg.headingId}>
        <PortableText value={seg.blocks} />
      </div>
    );
  }
  return <PortableText value={seg.blocks} />;
})}

<style>
  .blog-inline-image {
    margin: 2rem 0;
    text-align: center;
  }
  .blog-inline-image img {
    max-width: 100%;
    border-radius: 4px;
  }

  .blog-release-box {
    border-left: 4px solid var(--rust);
    padding: 20px 24px;
    margin: 32px 0;
    background: rgba(184, 92, 60, 0.04);
  }

  .blog-release-box strong {
    display: block;
    margin-bottom: 12px;
    color: var(--rust);
    font-weight: 600;
  }

  .blog-release-box p {
    margin: 0;
    font-size: 0.95em;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .blog-release-box a {
    color: var(--rust);
    text-decoration: underline;
  }

  .blog-release-box a:hover {
    opacity: 0.8;
  }
</style>
